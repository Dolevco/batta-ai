{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.39.26.7824",
      "templateHash": "2512698965067214587"
    }
  },
  "parameters": {
    "baseName": {
      "type": "string",
      "metadata": {
        "description": "Short base name used to derive resource names."
      }
    },
    "location": {
      "type": "string",
      "metadata": {
        "description": "Azure region."
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Resource tags."
      }
    },
    "storageAccountNameOverride": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Override the derived storage account name (to adopt an existing account)."
      }
    }
  },
  "variables": {
    "derivedStorageName": "[format('{0}stor', take(toLower(replace(replace(replace(parameters('baseName'), '-', ''), '_', ''), '.', '')), 20))]",
    "resolvedStorageName": "[if(empty(parameters('storageAccountNameOverride')), variables('derivedStorageName'), parameters('storageAccountNameOverride'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-01-01",
      "name": "[variables('resolvedStorageName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "Standard_LRS"
      },
      "kind": "StorageV2",
      "properties": {
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": true,
        "supportsHttpsTrafficOnly": true
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices",
      "apiVersion": "2023-01-01",
      "name": "[format('{0}/{1}', variables('resolvedStorageName'), 'default')]",
      "properties": {},
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('resolvedStorageName'))]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/fileServices",
      "apiVersion": "2023-01-01",
      "name": "[format('{0}/{1}', variables('resolvedStorageName'), 'default')]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('resolvedStorageName'))]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/fileServices/shares",
      "apiVersion": "2023-01-01",
      "name": "[format('{0}/{1}/{2}', variables('resolvedStorageName'), 'default', 'qdrant-data')]",
      "properties": {
        "shareQuota": 10
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/fileServices', variables('resolvedStorageName'), 'default')]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/fileServices/shares",
      "apiVersion": "2023-01-01",
      "name": "[format('{0}/{1}/{2}', variables('resolvedStorageName'), 'default', 'neo4j-data')]",
      "properties": {
        "shareQuota": 20
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/fileServices', variables('resolvedStorageName'), 'default')]"
      ]
    }
  ],
  "outputs": {
    "storageAccountId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Storage/storageAccounts', variables('resolvedStorageName'))]"
    },
    "storageAccountName": {
      "type": "string",
      "value": "[variables('resolvedStorageName')]"
    },
    "storageKey": {
      "type": "string",
      "value": "[listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('resolvedStorageName')), '2023-01-01').keys[0].value]"
    },
    "shareName": {
      "type": "string",
      "value": "qdrant-data"
    },
    "neo4jShareName": {
      "type": "string",
      "value": "neo4j-data"
    },
    "staticWebsiteUrl": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Storage/storageAccounts', variables('resolvedStorageName')), '2023-01-01').primaryEndpoints.web]"
    }
  }
}