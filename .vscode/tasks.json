{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev:api",
      "command": "pnpm",
      "args": ["--filter", "@batta/api", "dev"],
      "type": "shell",
      "isBackground": true,
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": {
        "owner": "api-server",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*tsx watch.*",
          "endsPattern": "^.*MCP endpoint:.*localhost"
        }
      }
    },
    {
      "label": "build:core",
      "command": "pnpm",
      "args": ["--filter", "@batta/core", "build"],
      "type": "shell",
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "build:shared",
      "command": "pnpm",
      "args": ["--filter", "@batta/shared", "build"],
      "type": "shell",
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "build:data-indexer",
      "command": "pnpm",
      "args": ["--filter", "@batta/data-indexer", "build"],
      "type": "shell",
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "build:api",
      "command": "pnpm",
      "args": ["--filter", "@batta/api", "build"],
      "type": "shell",
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "build:all",
      "command": "pnpm",
      "args": ["build"],
      "type": "shell",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
