{
  "name": "batta-ai",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --if-present test",
    "lint": "pnpm -r --if-present lint",
    "clean": "pnpm -r clean",
    "dev:api": "pnpm --filter @batta/api dev",
    "dev:ui": "pnpm --filter @batta/ui dev",
    "dev": "pnpm --parallel --filter @batta/api --filter @batta/ui dev",
    "doctor": "node scripts/doctor.mjs",
    "setup:azure": "bash ./scripts/setup-azure.sh",
    "deploy:api": "bash ./scripts/deploy-api.sh",
    "deploy:ui": "bash ./scripts/deploy-ui.sh",
    "deploy": "bash ./scripts/deploy-api.sh && bash ./scripts/deploy-ui.sh",
    "docker": "docker compose up --build -d",
    "docker:https": "docker compose -f docker-compose-https.yml up --build -d",
    "lint:unused": "knip"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jest": "^29.5.0",
    "knip": "^6.15.0",
    "typescript": "^5.3.0"
  },
  "workspaces": [
    "packages/*"
  ]
}
