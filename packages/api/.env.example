# API Server Configuration
PORT=3001

# HTTPS / TLS configuration
# HTTPS is required for the OAuth flow with Entra ID (Entra redirects to https:// URIs).
# Use mkcert for a trusted local cert (recommended):
#   mkcert -install && mkcert -key-file ssl3/key.pem -cert-file ssl3/cert.pem localhost 127.0.0.1
# Or generate a self-signed cert with SAN, then trust it in your keychain:
#   openssl req -x509 -newkey rsa:2048 -keyout ssl3/key.pem -out ssl3/cert.pem \
#     -sha256 -days 825 -nodes -subj "/CN=localhost" \
#     -addext "subjectAltName=DNS:localhost,IP:127.0.0.1"
#   security add-trusted-cert -d -r trustRoot -k ~/Library/Keychains/login.keychain-db ssl3/cert.pem
# ssl3/ is the active cert location (relative to workspace root).
HTTPS=true
SSL_KEY_PATH=../../ssl3/key.pem
SSL_CERT_PATH=../../ssl3/cert.pem

# MCP Security Review endpoint is embedded in the API at POST /mcp.
# No separate process needed. Coding agents (GitHub Copilot, Claude Code) connect to:
#   https://localhost:3001/mcp  (local dev with HTTPS=true – required for Entra OAuth)
#   https://api.your-domain.com/mcp   (production)
#
# MCP_ISSUER_URL must match the URL clients use to reach /mcp.
# All /.well-known endpoints and JWT iss claims are based on this value.
MCP_ISSUER_URL=https://localhost:3001

# ── Identity provider for MCP (choose one) ────────────────────────────────────
# The MCP server is a pure RESOURCE SERVER. It never issues tokens.
# Tokens are issued by the configured identity provider and validated here via
# JWKS (RS256 only). Coding agents are PUBLIC CLIENTS (Auth Code + PKCE, no secret).
#
# Option A: Microsoft Entra ID (same App Registration as the UI)
#
#   Setup:
#     1. Entra → App registrations → your app → "Expose an API"
#        Add scope: security_review  (URI: api://<ENTRA_CLIENT_ID>/security_review)
#     2. Same app → "Authentication" → add redirect URIs:
#        https://vscode.dev/redirect              ← required for VS Code / Claude Code MCP OAuth
#        https://localhost:3001/oauth/callback    ← local dev callback
#     3. The UI uses the same app as VITE_MSAL_CLIENT_ID.
#
#   ENTRA_TENANT_ID     – Entra tenant GUID (use "common" for multi-tenant)
#   ENTRA_CLIENT_ID     – App Registration client ID
#   ENTRA_AUDIENCE      – Expected aud claim (default: api://<ENTRA_CLIENT_ID>)
#   ENTRA_MCP_CLIENT_ID – Separate public-client app ID for coding agents (optional,
#                          defaults to ENTRA_CLIENT_ID; set only if you created a second app reg)
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=bab4b384-f55f-41bb-8e25-337313ab5494
# ENTRA_AUDIENCE=api://bab4b384-f55f-41bb-8e25-337313ab5494
# ENTRA_MCP_CLIENT_ID=

# Redirect URIs – must be registered in your Entra App Registration → Authentication:
#   https://vscode.dev/redirect          ← required for VS Code built-in MCP OAuth
#   http://localhost:3001/oauth/callback ← local / other clients (set MCP_CALLBACK_URL to override)

# Option B: Generic OIDC (Okta, Auth0, Keycloak, Google Workspace, etc.)
#
#   OIDC_AUTHORITY          – Provider base URL (e.g. https://your-domain.okta.com)
#   OIDC_CLIENT_ID          – Client ID registered with the provider
#   OIDC_AUDIENCE           – Expected aud claim (default: OIDC_CLIENT_ID)
#   OIDC_JWKS_URI           – JWKS endpoint (default: {authority}/.well-known/jwks.json)
#   OIDC_ISSUER             – Expected iss claim (default: OIDC_AUTHORITY)
#   OIDC_AUTHORIZATION_URL  – Authorization endpoint (default: {authority}/authorize)
#   OIDC_TOKEN_URL          – Token endpoint (default: {authority}/token)
#   OIDC_REVOCATION_URL     – Revocation endpoint (optional)
#   OIDC_MCP_CLIENT_ID      – Separate client ID for coding agents (optional)
# OIDC_AUTHORITY=
# OIDC_CLIENT_ID=

# Shared OAuth settings (apply to both providers)
# MCP_CALLBACK_URL – redirect URI registered with the identity provider.
# Defaults to https://localhost:3001/oauth/callback when HTTPS=true.
# Must be registered in your Entra App Registration → Authentication.
# MCP_CALLBACK_URL=https://localhost:3001/oauth/callback

TENANT_ID=default

# UI Configuration
UI_BASE_URL=https://localhost:3000

# Qdrant Configuration (for task persistence and long-term memory)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
TASK_COLLECTION_NAME=agent_tasks
CHAT_MESSAGE_COLLECTION_NAME=chat_messages

# Redis Configuration (for task execution event streaming)
REDIS_URL=redis://localhost:6379

# Slack OAuth Configuration
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=https://localhost:3000/oauth/slack/callback

# GitHub OAuth Configuration
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=secai-agents
GITHUB_REDIRECT_URI=https://localhost:3000/oauth/github/callback

# Azure OpenAI Configuration (if using Azure OpenAI in core package)
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT_NAME=
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=

# Neo4j Configuration (for security tools - relationship graph storage)
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=password
# NEO4J_DATABASE=neo4j

# Qdrant Configuration for Security Tools (if different from task persistence)
# QDRANT_COLLECTION_PREFIX=code_indexer
# AZURE_OPENAI_EMBEDDING_ENDPOINT=
# AZURE_OPENAI_EMBEDDING_API_KEY=
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
# AZURE_OPENAI_EMBEDDING_API_VERSION=
