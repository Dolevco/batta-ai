# API Server Configuration
PORT=3101

# HTTPS / TLS configuration
# Set HTTPS=false for local development (no cert required).
# Set HTTPS=true for production and generate a cert with mkcert:
#   mkcert -install && mkcert -key-file ssl3/key.pem -cert-file ssl3/cert.pem localhost 127.0.0.1
# ssl3/ is the active cert location (relative to workspace root).
HTTPS=false
# SSL_KEY_PATH=../../ssl3/key.pem
# SSL_CERT_PATH=../../ssl3/cert.pem

# MCP endpoint is embedded in the API at /api/mcp.
# Coding agents connect to: http://localhost:3101/api/mcp?repo=<repo-name>
# MCP_ISSUER_URL must match the URL clients use to reach /api/mcp.
MCP_ISSUER_URL=http://localhost:3101

# Disable all authentication checks (local dev only — never use in production).
# All requests are treated as TENANT_ID below.
AUTH_DISABLED=true

# Fixed tenant ID used when AUTH_DISABLED=true.
TENANT_ID=local

# PostgreSQL (matches docker-compose postgres service)
DATABASE_URL=postgresql://app:changeme@localhost:5432/app

# UI base URL (used for OAuth redirect URIs and CORS)
UI_BASE_URL=http://localhost:3100

# Redis (for task execution event streaming)
REDIS_URL=redis://localhost:6379

# Disable embeddings — indexing and reviews work without them.
# Set to true and configure an embedding provider to enable semantic search.
EMBEDDINGS_ENABLED=false

# ── Identity provider for MCP OAuth (production only) ─────────────────────────
# Not needed when AUTH_DISABLED=true.
#
# Option A: Microsoft Entra ID
#   Setup:
#     1. Entra → App registrations → your app → "Expose an API"
#        Add scope: security_review  (URI: api://<ENTRA_CLIENT_ID>/security_review)
#     2. Same app → "Authentication" → add redirect URIs:
#        https://vscode.dev/redirect              ← required for VS Code / Claude Code MCP OAuth
#        https://localhost:3101/oauth/callback    ← local dev callback
#
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_ID=
# ENTRA_AUDIENCE=api://YOUR-ENTRA-CLIENT-ID
# ENTRA_MCP_CLIENT_ID=

# Option B: Generic OIDC (Okta, Auth0, Keycloak, etc.)
# OIDC_AUTHORITY=
# OIDC_CLIENT_ID=

# ── Integrations ───────────────────────────────────────────────────────────────
# Slack OAuth
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_REDIRECT_URI=http://localhost:3100/oauth/slack/callback

# GitHub App
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_APP_SLUG=your-github-app-slug
# GITHUB_REDIRECT_URI=http://localhost:3100/oauth/github/callback

# ── LLM provider for chat and data-indexer ────────────────────────────────────
# LLM_PROVIDER=azure-openai
# LLM_PROVIDER=ollama

# Azure OpenAI
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=
# AZURE_OPENAI_API_VERSION=2024-12-01-preview
# AZURE_OPENAI_AUTH=use_llm_provider_key
# AZURE_OPENAI_SMALL_DEPLOYMENT=

# Ollama local chat
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_CHAT_MODEL=qwen2.5-coder:14b
# OLLAMA_SMALL_CHAT_MODEL=qwen2.5-coder:7b
# OLLAMA_NUM_CTX=32768
# OLLAMA_TIMEOUT_MS=300000

# ── Embeddings (requires EMBEDDINGS_ENABLED=true) ─────────────────────────────
# EMBEDDINGS_PROVIDER=azure-openai
# EMBEDDINGS_PROVIDER=ollama

# Azure OpenAI embeddings
# AZURE_OPENAI_EMBEDDING_ENDPOINT=
# AZURE_OPENAI_EMBEDDING_API_KEY=
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
# AZURE_OPENAI_EMBEDDING_API_VERSION=2024-12-01-preview

# Ollama embeddings. Keep dimension explicit; nomic-embed-text is 768.
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# OLLAMA_EMBEDDING_DIMENSION=768
