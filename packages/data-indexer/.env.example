# Data Indexer Environment Variables

# Provider selection
LLM_PROVIDER=azure-openai
EMBEDDINGS_ENABLED=true
EMBEDDINGS_PROVIDER=azure-openai

# Azure OpenAI chat and embeddings
AZURE_OPENAI_ENDPOINT=https://your-instance.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_EMBEDDING_ENDPOINT=https://your-instance.openai.azure.com/
AZURE_OPENAI_EMBEDDING_API_KEY=your-azure-openai-key
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Ollama local chat and embeddings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5-coder:14b
OLLAMA_SMALL_CHAT_MODEL=qwen2.5-coder:7b
OLLAMA_NUM_CTX=32768
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_EMBEDDING_DIMENSION=768
