# ─── API ──────────────────────────────────────────────────────────────────────

# Backend API base URL. Defaults to /api (works when the UI and API are served
# from the same origin or behind a reverse proxy).
# Set this when running the UI and API on separate ports locally.
# VITE_API_BASE=http://localhost:3101/api

# ─── Authentication ───────────────────────────────────────────────────────────

# Disable all authentication in the UI.
# Must be paired with AUTH_DISABLED=true on the API server.
# DO NOT set to true in production.
VITE_AUTH_DISABLED=false

# Microsoft Entra ID (Azure AD) — uncomment if using Microsoft authentication.
# VITE_MSAL_CLIENT_ID=your-azure-app-client-id
# VITE_MSAL_AUTHORITY=https://login.microsoftonline.com/your-tenant-id
# VITE_MSAL_REDIRECT_URI=http://localhost:3100

# Generic OIDC provider (GitHub, GitLab, Okta, etc.) — uncomment if using OIDC.
# VITE_OIDC_AUTHORITY=https://your-oidc-provider.com
# VITE_OIDC_CLIENT_ID=your-oidc-client-id
# VITE_OIDC_REDIRECT_URI=http://localhost:3100
