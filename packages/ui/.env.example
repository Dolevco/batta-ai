# Microsoft Entra ID (Azure AD) Configuration
# Uncomment and configure these if using Microsoft authentication
# VITE_MSAL_CLIENT_ID=your-client-id-here
# VITE_MSAL_AUTHORITY=https://login.microsoftonline.com/your-tenant-id
# VITE_MSAL_REDIRECT_URI=http://localhost:5173

# Custom OIDC Configuration
# Uncomment and configure these if using a custom OIDC provider
# VITE_OIDC_AUTHORITY=https://your-oidc-provider.com
# VITE_OIDC_CLIENT_ID=your-client-id-here
# VITE_OIDC_REDIRECT_URI=http://localhost:5173
